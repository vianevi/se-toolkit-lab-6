#!/usr/bin/env python3
"""
Agent module for interacting with LLM.
"""

import os
import json
import sys
from dotenv import load_dotenv
from openai import OpenAI


class Agent:
    """A simple agent that calls an LLM."""
    
    def __init__(self):
        """Initialize the agent with API key from environment."""
        # Load environment variables from .env.agent.secret
        load_dotenv('.env.agent.secret')
        
        # Get API key
        api_key = os.getenv('OPENAI_API_KEY')
        if not api_key:
            raise ValueError(
                "OPENAI_API_KEY not found. "
                "Please set it in .env.agent.secret file."
            )
        
        # Initialize OpenAI client
        self.client = OpenAI(api_key=api_key)
        self.model = "gpt-3.5-turbo"
    
    def call_llm(self, prompt):
        """
        Call the LLM with the given prompt.
        
        Args:
            prompt (str): The user prompt to send to the LLM
            
        Returns:
            str: The LLM's response
        """
        try:
            response = self.client.chat.completions.create(
                model=self.model,
                messages=[
                    {"role": "system", "content": "You are a helpful assistant."},
                    {"role": "user", "content": prompt}
                ],
                temperature=0.7,
                max_tokens=500
            )
            
            return response.choices[0].message.content
            
        except Exception as e:
            return f"Error calling LLM: {str(e)}"
    
    def format_response(self, answer):
        """
        Format the response as JSON with answer and tool_calls.
        
        Args:
            answer (str): The LLM's answer
            
        Returns:
            str: JSON string with answer and empty tool_calls
        """
        response = {
            "answer": answer,
            "tool_calls": []  # Empty for now, will be used in future tasks
        }
        return json.dumps(response, ensure_ascii=False)


def main():
    """Main entry point for the agent."""
    # Get prompt from command line arguments
    if len(sys.argv) < 2:
        print("Error: Please provide a prompt")
        print("Usage: uv run agent.py \"your prompt here\"")
        sys.exit(1)
    
    prompt = sys.argv[1]
    
    # Create agent and call LLM
    try:
        agent = Agent()
        answer = agent.call_llm(prompt)
        formatted_response = agent.format_response(answer)
        print(formatted_response)
    except Exception as e:
        error_response = {
            "answer": f"Error: {str(e)}",
            "tool_calls": []
        }
        print(json.dumps(error_response))
        sys.exit(1)


if __name__ == "__main__":
    main()
